---
const townLinks = [
  { label: 'Medford', href: '/cabinet-refinishing-medford/' },
  { label: 'Malden', href: '/cabinet-refinishing-malden/' },
  { label: 'Everett', href: '/cabinet-refinishing-everett/' },
  { label: 'Arlington', href: '/cabinet-refinishing-arlington/' },
  { label: 'Somerville', href: '/cabinet-refinishing-somerville/' },
  { label: 'Cambridge', href: '/cabinet-refinishing-cambridge/' },
  { label: 'Woburn', href: '/cabinet-refinishing-woburn/' },
  { label: 'Winchester', href: '/cabinet-refinishing-winchester/' },
];
---

<header>
  <nav class="nav" aria-label="Main navigation">
    <a class="brand" href="/" aria-label="Jerry & Co. Home Improvement — home">
      <img class="logo-img" src="/img/brand/logo-navbar.png" alt="Jerry & Co. Home Improvement" height="44" width="auto" />
    </a>

    <!-- Desktop nav -->
    <ul class="nav-links" role="list">
      <!-- Services dropdown -->
      <li class="nav-item has-dropdown">
        <button class="nav-trigger" aria-expanded="false" aria-haspopup="true">
          Services <span class="nav-arrow" aria-hidden="true">▾</span>
        </button>
        <ul class="dropdown" role="list">
          <li><a href="/#cabinet-feature">Cabinet Refinishing</a></li>
          <li><a href="/#services">Bathroom Refresh</a></li>
          <li><a href="/#services">Interior Painting</a></li>
          <li><a href="/#services">Full Bathroom Renovation</a></li>
        </ul>
      </li>

      <!-- Why Refinish dropdown -->
      <li class="nav-item has-dropdown">
        <button class="nav-trigger" aria-expanded="false" aria-haspopup="true">
          Why Refinish <span class="nav-arrow" aria-hidden="true">▾</span>
        </button>
        <ul class="dropdown" role="list">
          <li><a href="/cabinet-refinishing-vs-replacement/">vs. Replacement</a></li>
          <li><a href="/our-process/">Our Process</a></li>
          <li><a href="/guarantee/">Guarantee</a></li>
          <li><a href="/financing/">Financing</a></li>
        </ul>
      </li>

      <li><a href="/projects/" class="nav-link">Our Work</a></li>
      <li><a href="/gallery/" class="nav-link">Gallery</a></li>
      <li><a href="/faq/" class="nav-link">FAQ</a></li>
      <li><a href="/about/" class="nav-link">About</a></li>

      <!-- Areas dropdown -->
      <li class="nav-item has-dropdown">
        <button class="nav-trigger" aria-expanded="false" aria-haspopup="true">
          Areas <span class="nav-arrow" aria-hidden="true">▾</span>
        </button>
        <ul class="dropdown dropdown-wide" role="list">
          {townLinks.map((town) => (
            <li><a href={town.href}>{town.label}</a></li>
          ))}
        </ul>
      </li>
    </ul>

    <div class="nav-cta">
      <a class="nav-phone" href="tel:+13476026801">
        <span class="live-dot" aria-hidden="true"></span>(347) 602-6801
      </a>
      <a class="btn btn-gold" href="/#estimate">Get video estimate — same day</a>
    </div>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="navOpen" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobileNav">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Mobile overlay -->
  <div class="nav-scrim" id="navScrim" aria-hidden="true"></div>
  <div class="mobile-nav" id="mobileNav" role="dialog" aria-modal="true" aria-label="Navigation" aria-hidden="true">
    <button class="mobile-close" id="navClose" aria-label="Close navigation menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <ul role="list">
      <li><strong>Services</strong></li>
      <li><a href="/#services">Cabinet Refinishing</a></li>
      <li><a href="/#services">Bathroom Refresh</a></li>
      <li><a href="/#services">Interior Painting</a></li>
      <li><a href="/#services">Full Bathroom Renovation</a></li>
      <li class="nav-divider"></li>
      <li><strong>Why Refinish</strong></li>
      <li><a href="/cabinet-refinishing-vs-replacement/">vs. Replacement</a></li>
      <li><a href="/our-process/">Our Process</a></li>
      <li><a href="/guarantee/">Guarantee</a></li>
      <li><a href="/financing/">Financing</a></li>
      <li class="nav-divider"></li>
      <li><a href="/projects/">Our Work</a></li>
      <li><a href="/gallery/">Gallery</a></li>
      <li><a href="/faq/">FAQ</a></li>
      <li><a href="/about/">About</a></li>
      <li class="nav-divider"></li>
