---
const townLinks = [
  { label: 'Medford', href: '/cabinet-refinishing-medford/' },
  { label: 'Malden', href: '/cabinet-refinishing-malden/' },
  { label: 'Everett', href: '/cabinet-refinishing-everett/' },
  { label: 'Arlington', href: '/cabinet-refinishing-arlington/' },
  { label: 'Somerville', href: '/cabinet-refinishing-somerville/' },
  { label: 'Cambridge', href: '/cabinet-refinishing-cambridge/' },
  { label: 'Woburn', href: '/cabinet-refinishing-woburn/' },
  { label: 'Winchester', href: '/cabinet-refinishing-winchester/' },
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
  "name": "Jerry & Co. Home Improvement LLC",
  "description": "Factory-grade cabinet refinishing and bathroom refresh for condo owners across Greater Boston — built around your building's rules, your neighbors, and your timeline.",
  "url": "https://www.jerryandcohome.com",
  "telephone": "(347) 602-6801",
  "email": "jerry@jerryandcohome.com",
  "founder": {
    "@type": "Person",
    "name": "Jeremiah Ugbine"
  },
  "foundingDate": "2019-04-10",
  "areaServed": [
    "Medford, MA", "Malden, MA", "Everett, MA", "Arlington, MA",
    "Somerville, MA", "Cambridge, MA", "Woburn, MA", "Winchester, MA"
  ],
  "sameAs": [
    "https://www.instagram.com/improvewithjerryandco",
    "https://www.tiktok.com/@improvewithjerryandco",
    "https://www.youtube.com/@improvewithjerryandco",
    "https://www.facebook.com/improvewithjerryandco",
    "https://www.pinterest.com/improvewithjerryandco"
  ],
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "name": "Massachusetts Home Improvement Contractor Registration",
    "identifier": "MA HIC #208336"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "5",
    "bestRating": "5",
    "worstRating": "1"
  }
};
const newsletterId = import.meta.env.FORMSPARK_NEWSLETTER_ID ?? '';
const newsletterAction = newsletterId ? `https://submit-form.com/${newsletterId}` : '#';
---

<footer>
  <div class="wrap footer-grid">
    <!-- Col 1: Brand -->
    <div>
      <a class="footer-brand" href="/" aria-label="Jerry & Co. Home Improvement">
        <img src="/img/brand/logo-icon-mark.svg" alt="" class="footer-logo" height="36" width="auto" aria-hidden="true" />
        <span class="brand-text">Jerry &amp; Co.</span>
      </a>
      <p class="footer-blurb">
        Factory-grade cabinet refinishing and bathroom refresh for condo owners across Greater Boston — built around your building's rules, your neighbors, and your timeline. Starting at $2,000.
      </p>
      <div class="footer-contact">
        <a href="tel:+13476026801" class="footer-phone">
          <span class="live-dot" aria-hidden="true"></span>(347) 602-6801
        </a>
        <a href="mailto:jerry@jerryandcohome.com">jerry@jerryandcohome.com</a>
        <a href="https://www.jerryandcohome.com" style="color:rgba(247,243,234,0.35);font-size:11px;letter-spacing:0.03em;">www.jerryandcohome.com</a>
      </div>
      <!-- Social icons -->
      <div class="social-row" aria-label="Social media links">
        <a href="https://www.instagram.com/improvewithjerryandco" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://www.tiktok.com/@improvewithjerryandco" aria-label="TikTok" rel="noopener noreferrer" target="_blank">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.69a4.85 4.85 0 01-1.01-.0z"/></svg>
        </a>
        <a href="https://www.youtube.com/@improvewithjerryandco" aria-label="YouTube" rel="noopener noreferrer" target="_blank">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6a3 3 0 00-2.1 2.1C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 002.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/></svg>
        </a>
        <a href="https://www.facebook.com/improvewithjerryandco" aria-label="Facebook" rel="noopener noreferrer" target="_blank">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.41 18.63 0 12 0S0 5.41 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.8-4.7 4.54-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.5c-1.49 0-1.96.93-1.96 1.89v2.26h3.32l-.53 3.49h-2.79V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
        </a>
        <a href="https://www.pinterest.com/improvewithjerryandco" aria-label="Pinterest" rel="noopener noreferrer" target="_blank">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.16 9.44 7.63 11.21-.1-.95-.2-2.42.04-3.46.22-.93 1.47-6.24 1.47-6.24s-.37-.75-.37-1.86c0-1.75 1.01-3.06 2.28-3.06 1.07 0 1.59.81 1.59 1.77 0 1.08-.69 2.69-1.04 4.18-.3 1.25.61 2.26 1.84 2.26 2.2 0 3.9-2.32 3.9-5.66 0-2.96-2.13-5.03-5.17-5.03-3.52 0-5.59 2.64-5.59 5.37 0 1.06.41 2.2.92 2.82a.37.37 0 01.08.36c-.09.39-.3 1.25-.34 1.42-.05.23-.18.28-.41.17-1.54-.72-2.5-2.97-2.5-4.78 0-3.89 2.82-7.46 8.14-7.46 4.27 0 7.59 3.04 7.59 7.1 0 4.24-2.67 7.65-6.38 7.65-1.25 0-2.42-.65-2.82-1.41l-.77 2.86c-.28 1.07-1.03 2.42-1.53 3.24C10.56 23.92 11.27 24 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0z"/></svg>
        </a>
      </div>
    </div>

    <!-- Col 2: Services -->
    <div class="footer-col">
      <h4>Services</h4>
      <ul>
        <li><a href="/#cabinet-feature">Cabinet Refinishing</a></li>
        <li><a href="/#services">Bathroom Refresh</a></li>
        <li><a href="/#services">Interior Painting</a></li>
        <li><a href="/#services">Full Bathroom Renovation</a></li>
        <li><a href="/#estimate">Get a free estimate</a></li>
      </ul>
    </div>

    <!-- Col 3: Resources -->
    <div class="footer-col">
      <h4>Resources</h4>
      <ul>
        <li><a href="/guides/cabinet-refinishing/">Cabinet Guide</a></li>
        <li><a href="/guides/bathroom-refresh/">Bathroom Guide</a></li>
        <li><a href="/guides/interior-painting/">Painting Guide</a></li>
        <li><a href="/guides/bathroom-renovation/">Full Reno Guide</a></li>
        <li><a href="/cabinet-refinishing-vs-replacement/">Refinish vs. Replace</a></li>
        <li><a href="/cabinet-quiz/">Cabinet Quiz</a></li>
        <li><a href="/colors/">Color Gallery</a></li>
        <li><a href="/faq/">FAQ</a></li>
      </ul>
    </div>

    <!-- Col 4: Company -->
    <div class="footer-col">
      <h4>Company</h4>
      <ul>
        <li><a href="/about/">About</a></li>
        <li><a href="/our-process/">Our Process</a></li>
        <li><a href="/guarantee/">Guarantee</a></li>
        <li><a href="/financing/">Financing</a></li>
        <li><a href="/projects/">Our Work</a></li>
        <li><a href="/gallery/">Gallery</a></li>
      </ul>
    </div>

    <!-- Col 5: Service Areas -->
    <div class="footer-col">
      <h4>Service Areas</h4>
      <ul>
        {townLinks.map((town) => (
          <li><a href={town.href}>{town.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Newsletter signup -->
  <div class="footer-newsletter wrap">
    <div class="fn-copy">
      <p class="fn-headline">The Boston condo owner's home improvement newsletter — one useful update a month.</p>
      <p class="fn-sub">For homeowners who want the job done right, not just done.</p>
    </div>
    <form class="fn-form" id="fn-form" action={newsletterAction} method="post" aria-label="Newsletter signup">
      <label for="fnEmail" class="sr-only">Email address</label>
      <input
        id="fnEmail"
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        autocomplete="email"
        class="fn-input"
      />
      <!-- Honeypot spam guard -->
      <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
      <button type="submit" class="fn-btn" id="fn-btn">Send me the guide</button>
    </form>
    <p class="fn-success" id="fn-success" hidden>You're in — check your inbox.</p>
  </div>

  <div class="footer-bottom wrap">
    <p class="footer-legal">
      © 2026 Jerry &amp; Co. Home Improvement LLC · <a href="/about/" style="color:inherit;">MA HIC #208336</a> · All in-unit work performed with building-compliant containment and low-VOC materials.
    </p>
    <div class="footer-legal-links">
      <a href="/guarantee/">Guarantee</a>
      <a href="/financing/">Financing</a>
      <a href="/faq/">FAQ</a>
      <a href="/privacy/">Privacy Policy</a>
      <a href="/terms/">Terms of Service</a>
    </div>
  </div>

  <!-- LocalBusiness JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
</footer>

<style>
  footer {
    background: var(--ink);
    border-top: 1px solid var(--line-dark);
    color: rgba(247, 243, 234, 0.6);
    position: relative;
    overflow: hidden;
  }
  /* Ghost serif watermark — agency texture */
  footer::before {
    content: 'J&C';
    position: absolute;
    right: -2%;
    bottom: -10%;
    font-family: var(--font-serif);
    font-size: clamp(100px, 16vw, 220px);
    font-weight: 600;
    color: rgba(247, 243, 234, 0.018);
    line-height: 1;
    user-select: none;
    pointer-events: none;
    letter-spacing: -0.04em;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr 1fr;
    gap: var(--sp-6);
    padding-top: clamp(56px, 7vw, 96px);
    padding-bottom: 40px;
    position: relative;
  }

  /* Brand column */
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    text-decoration: none;
    color: inherit;
    width: fit-content;
    transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s ease;
  }
  .footer-brand:hover { transform: scale(1.04); opacity: 0.85; }
  .footer-logo {
    height: 36px;
    width: auto;
    flex-shrink: 0;
  }
  .footer-brand .brand-text {
    font-family: var(--font-serif);
    font-size: 18px;
    letter-spacing: 0.02em;
    color: var(--bone);
    font-weight: 500;
  }

  .footer-blurb {
    max-width: 32ch;
    font-size: 14.5px;
    margin: 0 0 20px;
    line-height: 1.75;
    color: rgba(247, 243, 234, 0.48);
  }

  /* Contact details in footer brand col */
  .footer-contact {
    margin-bottom: 20px;
  }
  .footer-contact a {
    display: block;
    font-size: 17px;
    font-weight: 600;
    color: var(--gold);
    text-decoration: none;
    letter-spacing: 0.01em;
    line-height: 1.8;
    transition: color 0.15s;
  }
  .footer-contact a:hover { color: var(--bone); }

  .footer-phone {
    display: inline-flex !important;
    align-items: center;
    gap: 7px;
  }
  .live-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    position: relative;
  }
  .live-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: #22c55e;
    opacity: 0.35;
    animation: livepulse 1.8s ease-out infinite;
  }
  @keyframes livepulse {
    0%   { transform: scale(1);   opacity: 0.35; }
    70%  { transform: scale(2.2); opacity: 0; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  .social-row {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-top: 4px;
  }
  .social-row a {
    color: rgba(247, 243, 234, 0.38);
    transition: color 0.2s ease, transform 0.2s ease;
    text-decoration: none;
    display: flex;
  }
  .social-row a:hover {
    color: var(--gold);
    transform: translateY(-2px) scale(1.15);
  }
  .social-row svg { width: 17px; height: 17px; }

  /* Link columns */
  .footer-col h4 {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(247, 243, 234, 0.28);
    margin: 0 0 18px;
    font-family: var(--font-sans);
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
    font-size: 14.5px;
  }
  .footer-col a {
    text-decoration: none;
    color: rgba(247, 243, 234, 0.52);
    transition: color 0.15s;
    letter-spacing: 0.01em;
    line-height: 1.4;
  }
  .footer-col a:hover { color: var(--bone); }

  /* Newsletter band */
  .footer-newsletter {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px 48px;
    padding-top: 36px;
    padding-bottom: 36px;
    border-top: 1px solid var(--line-dark);
    flex-wrap: wrap;
  }
  .fn-copy { flex: 1; min-width: 220px; }
  .fn-headline {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    color: var(--bone);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
    line-height: 1.35;
  }
  .fn-sub {
    font-size: 13px;
    color: rgba(247, 243, 234, 0.38);
    margin: 0;
    line-height: 1.6;
  }
  .fn-form {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .fn-input {
    height: 44px;
    padding: 0 16px;
    border: 1px solid rgba(247, 243, 234, 0.18);
    border-radius: var(--radius-xs);
    background: rgba(247, 243, 234, 0.06);
    color: var(--bone);
    font-family: var(--font-sans);
    font-size: 14px;
    width: 220px;
    outline: none;
    transition: border-color 0.2s;
  }
  .fn-input::placeholder { color: rgba(247, 243, 234, 0.3); }
  .fn-input:focus { border-color: var(--gold); }
  .fn-btn {
    height: 44px;
    padding: 0 22px;
    background: var(--gold);
    color: var(--ink);
    border: none;
    border-radius: var(--radius-xs);
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.18s, transform 0.18s;
    white-space: nowrap;
  }
  .fn-btn:hover { background: var(--gold-deep); color: var(--bone); transform: translateY(-1px); }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--line-dark);
    padding-top: 20px;
    padding-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 32px;
    position: relative;
  }
  .footer-legal {
    font-size: 11px;
    color: rgba(247, 243, 234, 0.3);
    letter-spacing: 0.01em;
    line-height: 1.6;
    margin: 0;
  }
  .footer-legal-links {
    display: flex;
    gap: 24px;
  }
  .footer-legal-links a {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(247, 243, 234, 0.28);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-legal-links a:hover { color: rgba(247, 243, 234, 0.6); }

  @media (max-width: 880px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; padding-top: 48px; }
  }
  @media (max-width: 600px) {
    .footer-newsletter { flex-direction: column; align-items: flex-start; gap: 20px; }
    .fn-input { width: 100%; }
    .fn-form { width: 100%; }
    .fn-btn { flex: 1; }
  }

  @media (max-width: 560px) {
    /* Brand spans full width; 4 link cols fall into 2×2 below it */
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px 20px; padding-top: 40px; }
    .footer-grid > div:first-child { grid-column: 1 / -1; }
    /* Compact the brand row on mobile */
    .footer-blurb { font-size: 13.5px; margin-bottom: 16px; }
    .footer-contact { margin-bottom: 16px; }
    .footer-contact a { font-size: 16px; line-height: 1.7; }
    .social-row { gap: 18px; }
    .social-row svg { width: 15px; height: 15px; }
    /* Tighter link columns */
    .footer-col ul { font-size: 13.5px; gap: 9px; }
    .footer-col h4 { margin-bottom: 14px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 360px) {
    .footer-grid { grid-template-columns: 1fr; }
  }

  .fn-success {
    font-size: 14px;
    color: var(--gold);
    font-weight: 600;
    flex-shrink: 0;
    letter-spacing: 0.01em;
    padding: 10px 0;
  }
</style>

<script>
  const form = document.getElementById('fn-form') as HTMLFormElement | null;
  const success = document.getElementById('fn-success') as HTMLElement | null;
  if (form && success) {
    form.addEventListener('submit', async (e) => {
      if (form.action === '#' || !form.action) return; // no endpoint configured
      e.preventDefault();
      const btn = document.getElementById('fn-btn') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Sending…';
      try {
        const data = new FormData(form);
        await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        form.hidden = true;
        success.hidden = false;
      } catch {
        btn.disabled = false;
        btn.textContent = 'Send me the guide';
      }
    });
  }
</script>
