---
interface Props {
  eyebrow?: string;
  headline?: string;
  ctaText?: string;
  ctaHref?: string;
  bgImage?: string;
  reassurance?: string;
}

const {
  eyebrow = 'Ready when you are',
  headline = 'Get your free video estimate',
  ctaText = 'Start my estimate',
  ctaHref = '/#estimate',
  bgImage,
  reassurance,
} = Astro.props;
---

<section class="cta-band" style={bgImage ? `--cta-bg-url: url('${bgImage}')` : ''} data-has-bg={bgImage ? 'true' : undefined}>
  <div class="wrap">
    <p class="eyebrow">{eyebrow}</p>
    <h2>{headline}</h2>
    <a class="btn btn-gold" href={ctaHref}>{ctaText}</a>
    {reassurance && <p class="cta-reassurance">{reassurance}</p>}
  </div>
</section>

<style>
  .cta-band {
    background: var(--forest);
    color: var(--bone);
    text-align: center;
    padding: clamp(72px, 8vw, 112px) 0;
    position: relative;
    overflow: hidden;
  }
  /* Ghost arrow backdrop */
  .cta-band::before {
    content: '→';
    position: absolute;
    right: 4%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-serif);
    font-size: clamp(100px, 15vw, 200px);
    color: rgba(247, 243, 234, 0.04);
    line-height: 1;
    user-select: none;
    pointer-events: none;
    z-index: 1;
  }
  /* Ambient kitchen photo layer — visible only when bgImage prop is set */
  .cta-band[data-has-bg]::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--cta-bg-url);
    background-size: cover;
    background-position: center;
    opacity: 0.18;
    mix-blend-mode: luminosity;
    pointer-events: none;
  }
  .cta-band .wrap { position: relative; z-index: 2; }
  .cta-band h2 {
    color: var(--bone);
    font-size: clamp(1.625rem, 3vw, 2.375rem);
    margin-bottom: 32px;
    letter-spacing: -0.03em;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-band .eyebrow {
    color: var(--gold);
    margin-bottom: 16px;
  }
  .cta-reassurance {
    margin: 20px auto 0;
    max-width: 520px;
    font-size: 0.875rem;
    color: rgba(247, 243, 234, 0.65);
  }
</style>
