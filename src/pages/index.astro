---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrustBar from '../components/TrustBar.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import MultiStepForm from '../components/MultiStepForm.astro';
import PlaceholderImage from '../components/PlaceholderImage.astro';
import TestimonialsCarousel from '../components/TestimonialsCarousel.astro';
import testimonials from '../../data/testimonials.json';

const title = 'Cabinet Refinishing Boston | From $2,000 | Factory 2K Finish | Jerry & Co.';
const description = 'Factory-grade cabinet refinishing for Boston condo owners. HOA-compliant, low-VOC, done in 2–5 days. MA HIC #208336.';

const cloud = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? 'dxuuydoee';
const cld = (id: string, w = 1440) =>
  `https://res.cloudinary.com/${cloud}/image/upload/f_auto,q_auto,w_${w}/${id}.jpg`;

const galleryItems: { cat: string; publicId: string; label: string; sub: string }[] = [
  { cat: 'cabinet',  publicId: 'featured/somerville-cabinet',              label: 'Cabinet refinishing', sub: 'Somerville — condo, deep forest green'       },
  { cat: 'bathroom', publicId: 'featured/cambridge-bathroom',              label: 'Bathroom refresh',    sub: 'Cambridge — triple-decker, gut-free'          },
  { cat: 'painting', publicId: 'featured/arlington-painting',              label: 'Interior painting',   sub: 'Arlington — condo pre-listing refresh'        },
  { cat: 'cabinet',  publicId: 'featured/medford-cabinet',                 label: 'Cabinet refinishing', sub: 'Medford — condo conversion, bone white'       },
  { cat: 'condo',    publicId: 'featured/malden-multi',                    label: 'Cabinet refinishing', sub: 'Malden — 3-unit multi-family turnover'        },
  { cat: 'bathroom', publicId: 'featured/everett-bathroom',                label: 'Bathroom refresh',    sub: 'Everett — condo board-approved update'        },
  { cat: 'painting', publicId: 'featured/woburn-painting',                 label: 'Interior painting',   sub: 'Woburn — owner-occupied colonial refresh'     },
  { cat: 'kitchen',  publicId: 'featured/winchester-kitchen',              label: 'Kitchen refresh',     sub: 'Winchester — cabinets + paint bundle'         },
  { cat: 'cabinet',  publicId: 'projects/medford-cabinet-01-after',        label: 'Cabinet refinishing', sub: 'Medford — bone white reveal'                  },
  { cat: 'bathroom', publicId: 'projects/everett-bathroom-01-after',       label: 'Bathroom refresh',    sub: 'Everett — condo board-approved update'        },
  { cat: 'painting', publicId: 'projects/woburn-painting-01-after',        label: 'Interior painting',   sub: 'Woburn — whole-unit colonial refresh'         },
  { cat: 'cabinet',  publicId: 'projects/somerville-cabinet-01-after',     label: 'Cabinet refinishing', sub: 'Somerville — navy shaker finish'              },
  { cat: 'kitchen',  publicId: 'projects/winchester-kitchen-01-after',     label: 'Kitchen refresh',     sub: 'Winchester — period colonial kitchen'         },
];

const processSteps = [
  { num: '01', slug: 'video-walkthrough',  alt: 'Owner walking a kitchen on a live video estimate call',        title: 'Your estimate in 60 minutes — no in-person appointment',  body: 'A 20-minute video call gets us a line-item estimate the same day — no waiting on a site visit. We also gather building access requirements, elevator reservation windows, and HOA documentation needs at this stage.' },
  { num: '02', slug: 'prep-containment',   alt: 'Sealed plastic dust containment inside a condo kitchen',       title: 'Day 1: Everything masked, tagged, and staged — while you’re at work', body: 'Fully sealed dust containment within your unit. All equipment staged within your unit — no lobby or hallway storage. Cabinets are removed, labeled, and your kitchen is fully masked.' },
  { num: '03', slug: 'hand-sand',          alt: 'Hand-sanding a cabinet door with a cork block',                title: 'Day 2: Hand-sanded, repaired, ready for finish', body: 'Hand-sanding only — no loud power tools that travel through condo walls. Every surface is sanded and any dents, gaps, or chips are filled and leveled.' },
  { num: '04', slug: 'spray-finish',       alt: 'HVLP spray applying 2K polyurethane to a cabinet door',       title: 'Day 2–3: The factory finish goes on — smooth, hard, and odor-gone by evening',    body: 'Low-VOC formula — safe for shared ventilation systems common in multi-unit buildings. A factory-grade polyurethane finish, sprayed in a controlled environment for a smooth, durable result.' },
  { num: '05', slug: 'cure-walkthrough',   alt: 'Finished kitchen walkthrough with labeled touch-up bottle',    title: 'Day 4–5: The reveal — plus your labeled touch-up bottle and 2-year guarantee', body: 'Doors cure, hardware is reinstalled, and we walk the finished space with you. Final walkthrough includes elevator condition check and hallway inspection before we leave.' },
];
---

<Base title={title} description={description}>
  <Fragment slot="head">
    {/* Preload the hero LCP image so the browser fetches it before layout is complete */}
    <link
      rel="preload"
      as="image"
      href={`https://res.cloudinary.com/${cloud}/image/upload/f_auto,q_auto,w_1200/hero/hero-after-kitchen-white.jpg`}
      imagesrcset={`https://res.cloudinary.com/${cloud}/image/upload/f_auto,q_auto,w_800/hero/hero-after-kitchen-white.jpg 800w, https://res.cloudinary.com/${cloud}/image/upload/f_auto,q_auto,w_1200/hero/hero-after-kitchen-white.jpg 1200w, https://res.cloudinary.com/${cloud}/image/upload/f_auto,q_auto,w_1600/hero/hero-after-kitchen-white.jpg 1600w`}
      imagesizes="100vw"
    />
  </Fragment>
  <Header />

  <!-- ===== HERO ===== -->
  <HeroCarousel />

  <!-- ===== TRUST BAR ===== -->
  <TrustBar />

  <!-- ===== CONDO-READY CARDS ===== -->
  <div class="condo-strip">
    <div class="wrap">
      <p class="eyebrow" data-reveal="up">7 years in Boston's most restrictive buildings</p>
      <h2 class="condo-strip-headline" data-reveal="up" data-delay="1">The HOA won't be a problem. The elevator window is already scheduled. Your neighbors won't hear a thing.</h2>
      <div class="condo-cards-grid">
        <div class="condo-bcard" data-reveal="scale" data-delay="1">
          <div class="condo-bcard-img">
            <PlaceholderImage publicId="condo/hoa-documentation" aspect="4/3" alt="Building manager and contractor reviewing HOA documentation" className="condo-bcard-photo" loading="lazy" />
          </div>
          <div class="condo-bcard-body">
            <h3>No board rejections. No project delays.</h3>
            <p>Building rules, documentation, and insurance certificates handled before day one — no surprises with your condo board.</p>
          </div>
        </div>
        <div class="condo-bcard" data-reveal="scale" data-delay="2">
          <div class="condo-bcard-img">
            <PlaceholderImage publicId="condo/neighbor-safe-process" aspect="4/3" alt="Clean, dust-contained cabinet refinishing workspace in a Boston condo" className="condo-bcard-photo" loading="lazy" />
          </div>
          <div class="condo-bcard-body">
            <h3>Zero Neighbor Drama</h3>
            <p>Low-VOC spray contained within your unit. By noon on spray day the unit smells normal — your neighbors won't know the work happened.</p>
          </div>
        </div>
        <div class="condo-bcard" data-reveal="scale" data-delay="3">
          <div class="condo-bcard-img">
            <PlaceholderImage publicId="condo/building-logistics" aspect="4/3" alt="Contractor coordinating elevator access in a Greater Boston condo building" className="condo-bcard-photo" loading="lazy" />
          </div>
          <div class="condo-bcard-body">
            <h3>You don't talk to building management once.</h3>
            <p>Elevator scheduling, condo board paperwork, neighbor notification — every logistics detail is coordinated by Jeremiah.</p>
          </div>
        </div>
      </div>
      <p class="condo-proof-line" data-reveal="up">7 years · 100+ projects · every building type in the ICC zone.</p>
    </div>
  </div>

  <!-- ===== SERVICES ===== -->
  <section id="services">
    <div class="wrap">
      <div class="section-head" data-reveal="up">
        <p class="eyebrow">What we do — and what it costs</p>
        <h2>From a 3-day kitchen transformation to a gut-free bath refresh — choose the scope that fits your condo.</h2>
        <p class="section-lede-center">You get three price options on every job — good, better, best — so you're never forced between cheap and right.</p>
      </div>
      <div class="services-grid">
        <div class="service-card featured" id="cabinet-feature" data-reveal="scale" data-delay="1">
          <PlaceholderImage
            publicId="services/cabinet-refinishing"
            alt="Satin white refinished cabinet door with brass knob"
            aspect="16/10"
            className="svc-img"
            caption="Service result photo"
            loading="lazy"
          />
          <div class="card-body">
            <h3>Cabinet refinishing — 2K factory finish</h3>
            <p class="price">$1,800 – $9,500</p>
            <p>Factory-grade 2K polyurethane spray finish on existing cabinet boxes — the look of new cabinets, the cost of paint. No demo, no dumpster, no elevator damage — done in 2–5 days. Compare to $20,000–$50,000 full replacement.</p>
            <p class="tag">2–5 days · the only factory-grade finish available in Greater Boston</p>
            <a class="svc-guide-link" href="/guides/cabinet-refinishing/">
              Is your kitchen a candidate? Self-assess before you call
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
          </div>
          <div class="card-badge-col">
            <span class="badge-featured">Featured this season</span>
          </div>
        </div>
        <div class="service-card" data-reveal="scale" data-delay="2">
          <PlaceholderImage
            publicId="services/bathroom-refresh"
            alt="Bright bathroom refresh with white subway tile"
            aspect="16/10"
            className="svc-img"
            caption="Service result photo"
            loading="lazy"
          />
          <div class="card-body">
            <h3>Gut-free bathroom refresh</h3>
            <p class="price">$2,800 – $6,500</p>
            <p>New tile, fixtures, and paint without demo. Gut-free refresh that meets condo renovation bylaws — no permit triggers in most ICC buildings. Starting at $2,800 — typically paired with cabinet refinishing for a full kitchen-and-bath update.</p>
            <p class="tag">2–5 days · most clients combine with cabinet refinishing</p>
            <a class="svc-guide-link" href="/guides/bathroom-refresh/">
              Tile, fixtures &amp; permit questions — sorted before the estimate
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
          </div>
        </div>
        <div class="service-card" data-reveal="scale" data-delay="3">
          <PlaceholderImage
            publicId="services/interior-painting"
            alt="Freshly painted bright living room with natural light"
            aspect="16/10"
            className="svc-img"
            caption="Service result photo"
            loading="lazy"
          />
          <div class="card-body">
            <h3>Lead-safe interior painting — low-VOC, contained within your unit</h3>
            <p class="price">$1,400 – $6,500</p>
            <p>Pre-1978 condo? We handle lead-safe prep, low-VOC product, and full containment — no building fines, no neighbor complaints.</p>
            <p class="tag">1–4 days · acknowledged within 60 min, quoted within 24 hrs</p>
            <a class="svc-guide-link" href="/guides/interior-painting/">
              Pre-1978 home? Color, sheen &amp; lead-safe — the full pre-project guide
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
          </div>
        </div>
        <div class="service-card" data-reveal="scale" data-delay="4">
          <PlaceholderImage
            publicId="services/full-bathroom-reno"
            alt="Complete bathroom renovation, dark tile and brass"
            aspect="16/10"
            className="svc-img"
            caption="Service result photo"
            loading="lazy"
          />
          <div class="card-body">
            <h3>Full bathroom renovation</h3>
            <p class="price">$6,500 – $18,000</p>
            <p>Complete gut renovation — subfloor, waterproofing, tile, and finish. May require building board approval — we help you navigate the documentation.</p>
            <p class="tag">5–12 days · written contract per MA law</p>
            <a class="svc-guide-link" href="/guides/bathroom-renovation/">
              Permits, board approval &amp; tile decisions — know before demo day
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
          </div>
        </div>
        <div class="service-card" data-reveal="scale" data-delay="5">
          <PlaceholderImage
            publicId="services/multi-unit"
            alt="Clean refreshed hallway of condo unit doors"
            aspect="16/10"
            className="svc-img"
            caption="Service result photo"
            loading="lazy"
          />
          <div class="card-body">
            <h3>Multi-unit cabinet &amp; bath refresh — per-unit preferred-vendor pricing</h3>
            <p class="price">Custom pricing</p>
            <p>Coordinated refresh for property managers, landlords, and building owners across multiple units. Scheduled around tenant occupancy and building rules. Same 2K factory finish across every unit — one contractor, one scope, per-unit fixed pricing.</p>
            <p class="tag">Turnover window guaranteed — ask about per-unit pricing</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section class="process-band" id="process">
    <div class="wrap">
      <div class="section-head" data-reveal="up">
        <p class="eyebrow">The 5-step factory-finish process</p>
        <h2>The Jerry &amp; Co. factory-finish process</h2>
        <p>You know exactly what happens each day — and your kitchen is back in 2–5 days.</p>
      </div>
      <div class="process-list">
        {processSteps.map((s, i) => (
          <div class="process-step" data-reveal="up" data-delay={String(i + 1)}>
            <PlaceholderImage
              publicId={`process/step-${s.num}-${s.slug}`}
              alt={s.alt}
              aspect="16/9"
              className="proc-img"
              loading="lazy"
            />
            <div class="ps-header">
              <div class="process-num">{s.num}</div>
              <h3>{s.title}</h3>
            </div>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
      <div class="process-link-row"><a href="/our-process/" class="btn btn-outline" data-ph-event="cta_clicked" data-ph-label="process_see_full">See our full process →</a></div>
    </div>
  </section>

  <!-- ===== GALLERY ===== -->
  <section id="gallery">
    <div class="wrap">
      <div class="section-head left" data-reveal="up">
        <p class="eyebrow">Real projects — Boston condos and triple-deckers</p>
        <h2>This is what $5,000 looks like in a Medford kitchen.</h2>
        <p class="section-lede">Real transformations in Greater Boston condos, triple-deckers, and multi-family units. Filter by service to see results from Medford to Cambridge to Winchester.</p>
      </div>

      <div class="filter-row" role="group" aria-label="Filter gallery by project type" data-reveal="in" data-delay="2">
        <button class="filter-btn active" data-filter="all">All projects</button>
        <button class="filter-btn" data-filter="cabinet">Cabinet refinishing</button>
        <button class="filter-btn" data-filter="bathroom">Bathroom refresh</button>
        <button class="filter-btn" data-filter="painting">Painting</button>
        <button class="filter-btn" data-filter="kitchen">Kitchen</button>
        <button class="filter-btn" data-filter="condo">Condo &amp; multi-unit</button>
      </div>

      <div class="gallery-grid" id="galleryGrid" data-reveal="in" data-delay="3">
        {galleryItems.map(item => (
          <div class="gallery-item" data-cat={item.cat}>
            <PlaceholderImage
              publicId={item.publicId}
              alt={`${item.label} — ${item.sub}`}
              aspect="3/4"
              className="gi-img"
              loading="lazy"
            />
            <div class="gi-overlay">
              <span class="g-label">{item.label}</span>
              <span class="g-sub">{item.sub}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="gallery-link-row"><a href="/gallery/" class="btn btn-outline-dark" data-ph-event="cta_clicked" data-ph-label="gallery_view_full">View full gallery →</a></div>
    </div>
  </section>

  <!-- ===== SERVICE AREA ===== -->
  <section id="area" class="area-section" style={`background-image: url('${cld('areas/boston-aerial')}')`}>
    <div class="wrap area-grid">
      <div data-reveal="left">
        <p class="eyebrow">Your town — yes, we work there</p>
        <h2>If your building has a freight elevator policy and an HOA, we've probably already worked in it.</h2>
        <p class="section-lede">If your building has HOA rules, a freight elevator policy, and neighbors who will notice the work — that's exactly where we work.</p>
        <div class="chip-group">
          <a href="/cabinet-refinishing-medford/" class="chip chip-primary">Medford</a>
          <a href="/cabinet-refinishing-malden/" class="chip chip-primary">Malden</a>
          <a href="/cabinet-refinishing-everett/" class="chip chip-primary">Everett</a>
          <a href="/cabinet-refinishing-arlington/" class="chip chip-primary">Arlington</a>
          <a href="/cabinet-refinishing-somerville/" class="chip chip-primary">Somerville</a>
          <a href="/cabinet-refinishing-cambridge/" class="chip chip-primary">Cambridge</a>
          <a href="/cabinet-refinishing-woburn/" class="chip chip-primary">Woburn</a>
          <a href="/cabinet-refinishing-winchester/" class="chip chip-primary">Winchester</a>
        </div>
        <p class="area-note">Locally owned and operated — serving the ICC zone for 7 years.</p>
      </div>
      <div data-reveal="right" data-delay="2">
        <p class="eyebrow">Expanding to your town</p>
        <h2 style="font-size:1.4rem;">Stoneham · Burlington · Wilmington · Reading — ask if we can help</h2>
        <p class="section-lede">Lower-competition towns with active renovation cycles and strong school-driven demand.</p>
        <div class="chip-group">
          <span class="chip chip-secondary">Stoneham</span>
          <span class="chip chip-secondary">Burlington</span>
          <span class="chip chip-secondary">Wilmington</span>
          <span class="chip chip-secondary">Reading</span>
        </div>
        <p class="area-note">Not listed? <a href="#estimate" style="color:var(--gold-deep);font-weight:600;">Ask</a> — we've said yes to towns not on this list.</p>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="testimonial-band" id="reviews">
    <div class="wrap">
      <p class="eyebrow" style="color:var(--gold);" data-reveal="up">What Boston condo owners say — in their own words</p>
      <h2 class="testimonial-headline" data-reveal="up" data-delay="1">Condo owners who didn't want the drama — here's what they found.</h2>
      <TestimonialsCarousel testimonials={testimonials} />
      <div class="testimonial-scores">
        <div class="testimonial-score-item" data-reveal="up" data-delay="1">
          <div class="testimonial-score-num">5.0</div>
          <div class="testimonial-score-src">Google</div>
          <div class="testimonial-score-label">Verified reviews</div>
        </div>
        <div class="testimonial-score-item" data-reveal="up" data-delay="3">
          <div class="testimonial-score-num">5.0</div>
          <div class="testimonial-score-src">Houzz Pro</div>
          <div class="testimonial-score-label">Portfolio verified</div>
        </div>
        <div class="testimonial-score-item" data-reveal="up" data-delay="5">
          <div class="testimonial-score-num">#208336</div>
          <div class="testimonial-score-src">Mass.gov</div>
          <div class="testimonial-score-label">MA HIC Licensed</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ESTIMATE FORM ===== -->
  <section class="estimate-band" id="estimate">
    <div class="wrap estimate-grid">
      <div class="estimate-info" data-reveal="left">
        <p class="eyebrow">3 details. 60 seconds. Same-day estimate.</p>
        <h2>3 details. 60 seconds. Same-day written estimate — no obligation.</h2>
        <p class="section-lede">A 60-second form. A written fixed-price estimate by end of day. Zero obligation.</p>
        <div class="estimate-stats">
          <div class="estimate-stat">
            <span class="num">1 hr</span>
            <span><strong>Personal callback</strong> to schedule your walkthrough</span>
          </div>
          <div class="estimate-stat">
            <span class="num">24 hr</span>
            <span><strong>Written estimate</strong> delivered, no waiting</span>
          </div>
          <div class="estimate-stat">
            <span class="num">3</span>
            <span><strong>Price options</strong> on every estimate — good, better, best. You pick the scope.</span>
          </div>
        </div>
        <p class="estimate-reassurance">Local accountability beats a national warranty — and if refinishing isn't the right call for your cabinets, we'll tell you upfront, not after a deposit.</p>
        <p class="estimate-reassurance">Send 4–6 photos or a short video walkthrough — even filmed on your phone — and you'll typically have a written quote the same day.</p>
      </div>
      <MultiStepForm />
    </div>
  </section>

  <!-- ===== TIERS / CLOSE ===== -->
  <section class="close-cta" id="tiers">
    <div class="close-cta-bg" aria-hidden="true">
      <PlaceholderImage publicId="cta/finished-kitchen-wide" aspect="16/9" alt="" className="close-cta-ph" />
      <div class="close-cta-overlay"></div>
    </div>
    <div class="wrap">
      <p class="eyebrow">Trusted by condo owners from Medford to Cambridge to Winchester</p>
      <h2>You won't be forced to choose between cheap and right.</h2>
      <p class="tiers-sub">So you're never stuck choosing between "do it cheap" and "do it right." Pick the tier that fits your budget — and upgrade only what matters.</p>
      <div class="tiers-grid">
        <div class="tier-card" data-reveal="scale" data-delay="1">
          <div class="tier-name">Good</div>
          <h3>Factory finish, core doors</h3>
          <p>Spray existing cabinet doors and boxes in your chosen color — the core factory-grade transformation.</p>
        </div>
        <div class="tier-card best" data-reveal="scale" data-delay="2">
          <div class="tier-name">Better</div>
          <h3>The complete transformation</h3>
          <p>Everything in Good, plus new soft-close hinges and updated hardware for a complete refresh.</p>
        </div>
        <div class="tier-card" data-reveal="scale" data-delay="3">
          <div class="tier-name">Best</div>
          <h3>Every surface, one standard.</h3>
          <p>Everything in Better, plus interior shelving refresh and matching island or pantry cabinetry.</p>
        </div>
      </div>
      <div class="tiers-footer">
        <a class="btn btn-gold" href="#estimate" data-ph-event="cta_clicked" data-ph-label="tiers_get_estimate">Start with a video walkthrough — pick my tier after</a>
        <p class="tiers-note">Every tier includes: zero lobby or hallway staging, low-VOC materials only, same-day cleanup, and a certificate of insurance for your HOA.</p>
        <div class="tiers-links">
          <a href="/financing/">Pay over time — ask about financing →</a>
          <span style="color:rgba(247,243,234,0.25)">·</span>
          <a href="/guarantee/">Workmanship guarantee →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="final-seal" id="why-jerry-co">
    <div class="wrap">
      <p class="eyebrow">Still on the fence? Fair.</p>
      <h2>Here's the whole deal, one more time.</h2>
      <p class="seal-lede">Three days from now, you could be walking into a kitchen that stops your partner in the doorway — <em>is this the same kitchen?</em> No dust. No deposit horror stories. Just the math, the guarantee, and a phone call to make it real.</p>

      <div class="seal-badges" data-reveal="in" data-delay="1">
        <div class="seal-badge">
