---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABand from '../components/CTABand.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaLD from '../components/SchemaLD.astro';
import Accordion from '../components/Accordion.astro';
import WisetackWidget from '../components/WisetackWidget.astro';
import PlaceholderImage from '../components/PlaceholderImage.astro';

const title = 'Pay Over Time — Cabinet Refinishing Financing | Jerry & Co.';
const description =
  'Pay over time for cabinet refinishing. Flexible payment plans for qualified homeowners — ask about financing when you request your free estimate. MA HIC #208336.';
const canonical = 'https://www.jerryandcohome.com/financing/';

const breadcrumbSchema = {
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.jerryandcohome.com/' },
    { '@type': 'ListItem', position: 2, name: 'Financing', item: canonical },
  ],
};

// Financing mini-FAQ — generic consumer financing facts, not Wisetack-specific
const financingFAQs = [
  {
    id: 'faq-credit',
    question: 'Does applying affect my credit score?',
    answer:
      '<p>Checking your rate uses a <strong>soft credit pull</strong> — it has no impact on your credit score. A hard pull only occurs if you choose to proceed with a loan offer, which you can always decline after seeing your options.</p>',
  },
  {
    id: 'faq-fee',
    question: 'Is there a fee or upfront cost to me?',
    answer:
      '<p>No fee to you as the borrower. You pay only the loan principal and any applicable interest per the terms you select. Merchant fees are separate and are not passed through to the customer.</p>',
  },
  {
    id: 'faq-speed',
    question: 'How quickly can I be approved?',
    answer:
      "<p>Most applicants receive a decision within seconds of submitting their application. From estimate sign-off to having a payment plan in place can happen within 24 hours — so your project timeline doesn't have to wait.</p>",
  },
];

// Whether Wisetack is live — used to determine CTA copy
const wisetackLive = !!import.meta.env.PUBLIC_WISETACK_MERCHANT_ID;

const cloud = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? 'dxuuydoee';
const cld = (path: string, w = 800) =>
  `https://res.cloudinary.com/${cloud}/image/upload/f_auto,q_auto,w_${w}/${path}.jpg`;
---

<Base title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <SchemaLD type="BreadcrumbList" data={breadcrumbSchema} />
  </Fragment>

  <Header />

  <!-- ===== HERO ===== -->
  <section class="hero-financing">
    <div class="fhero-media" aria-hidden="true">
      <PlaceholderImage publicId="financing/aspirational-kitchen" aspect="16/9" alt="" className="fhero-ph" loading="eager" />
      <div class="fhero-overlay"></div>
    </div>
    <div class="wrap">
      <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Financing' }]} />
      <div class="section-head" data-reveal="up">
        <p class="eyebrow">Your kitchen now. Pay it off over time.</p>
        <h1>Pay over time,<br/>not all at once.</h1>
        <p class="lede">
          A $5,000 kitchen refinishing project doesn't have to wait until you
          have $5,000 sitting there.
        </p>
        <a
          href={wisetackLive ? '#check-rate' : '/#estimate'}
          class="btn btn-gold"
          data-ph-event="cta_clicked"
          data-ph-label="financing_hero_cta"
        >
          {wisetackLive ? 'Check my rate' : 'Ask about financing on your estimate'}
        </a>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="section-steps">
    <div class="wrap steps-with-photo">
      <div class="steps-main" data-reveal="left">
        <div class="section-head">
          <p class="eyebrow">Three steps — from estimate to payment plan in 24 hours.</p>
          <h2>Three steps. 60 seconds. No paperwork pile.</h2>
        </div>
      <div class="steps-row">
        <div class="step">
          <div class="step-num" aria-hidden="true">01</div>
          <h3>Get your estimate</h3>
          <p>
            Submit your estimate request and mention you're interested in
            financing. Jeremiah will walk you through the project scope and
            total cost on the call.
          </p>
        </div>
        <div class="step-connector" aria-hidden="true"></div>
        <div class="step">
          <div class="step-num" aria-hidden="true">02</div>
          <h3>Apply with a soft check</h3>
          <p>
            A short application takes about 60 seconds. Checking your rate
            uses a soft credit pull — no impact to your score, no obligation
            to proceed.
          </p>
        </div>
        <div class="step-connector" aria-hidden="true"></div>
        <div class="step">
          <div class="step-num" aria-hidden="true">03</div>
          <h3>Choose your plan</h3>
          <p>
            Review your approved terms, pick the plan that fits your budget,
            and we schedule your project. Most approvals happen within 24 hours.
          </p>
        </div>
      </div>
      </div>
      <div class="steps-photo" data-reveal="right" data-delay="2">
        <img
          src={cld('pages/financing-approval-concept', 900)}
          alt="Homeowner reviewing financing approval on a phone — fast decision, no credit score impact"
          loading="lazy"
          decoding="async"
          onerror="this.style.opacity='0'"
        />
      </div>
    </div>
  </section>

  <!-- ===== WISETACK WIDGET ===== -->
  <section class="section-widget" id="check-rate">
    <div class="wrap widget-wrap">
      <WisetackWidget />
    </div>
  </section>

  <!-- ===== ILLUSTRATIVE EXAMPLES ===== -->
  <section class="section-examples">
    <div class="wrap">
      <div class="section-head" data-reveal="up">
        <p class="eyebrow">Illustrative monthly payments — at a glance.</p>
        <h2>Illustrative monthly payments.</h2>
        <p class="section-lede-center">
          Numbers below are illustrative only — final rate and monthly payment
          are determined at application based on creditworthiness and the term
          you select.
        </p>
      </div>
      <div class="examples-grid">
        <div class="example-card" data-reveal="scale" data-delay="1">
          <div class="ec-thumb">
            <PlaceholderImage publicId="financing/small-kitchen" aspect="4/3" alt="Small kitchen cabinet refinishing project" loading="lazy" />
          </div>
          <div class="ec-range">Small kitchen</div>
          <div class="ec-project">4–6 cabinet doors</div>
          <div class="ec-amount">~$2,500</div>
          <div class="ec-divider"></div>
          <div class="ec-payment">
            <span class="ec-from">from</span>
            <span class="ec-monthly">~$130</span>
            <span class="ec-per">/mo</span>
          </div>
          <div class="ec-note">Illustrative example — actual terms at application</div>
        </div>
        <div class="example-card example-card-featured" data-reveal="scale" data-delay="2">
          <div class="ec-thumb">
            <PlaceholderImage publicId="financing/full-kitchen" aspect="4/3" alt="Full kitchen cabinet refinishing project" loading="lazy" />
          </div>
          <div class="ec-pop-label">Most common</div>
          <div class="ec-range">Full kitchen</div>
          <div class="ec-project">10–12 cabinet doors</div>
          <div class="ec-amount">~$5,000</div>
          <div class="ec-divider"></div>
          <div class="ec-payment">
            <span class="ec-from">from</span>
            <span class="ec-monthly">~$165</span>
            <span class="ec-per">/mo</span>
          </div>
          <div class="ec-note">Illustrative example — actual terms at application</div>
        </div>
        <div class="example-card" data-reveal="scale" data-delay="3">
          <div class="ec-thumb">
            <PlaceholderImage publicId="financing/large-kitchen" aspect="4/3" alt="Large kitchen cabinet refinishing project" loading="lazy" />
          </div>
          <div class="ec-range">Large / premium</div>
          <div class="ec-project">15+ cabinet doors</div>
          <div class="ec-amount">~$8,500</div>
          <div class="ec-divider"></div>
          <div class="ec-payment">
            <span class="ec-from">from</span>
            <span class="ec-monthly">~$220</span>
            <span class="ec-per">/mo</span>
          </div>
          <div class="ec-note">Illustrative example — actual terms at application</div>
        </div>
      </div>
      <p class="examples-disclaimer">
        * Monthly payment estimates are illustrative and assume qualified credit.
        Actual rate, term, and monthly payment are determined at application.
        Final terms shown at application — no obligation to proceed.
      </p>
    </div>
  </section>

  <!-- ===== MINI-FAQ ===== -->
  <section class="section-financing-faq">
    <div class="wrap faq-wrap">
      <div class="section-head left">
        <p class="eyebrow">What to know before you apply.</p>
        <h2>Quick answers about financing.</h2>
      </div>
      <Accordion items={financingFAQs} groupLabel="Financing FAQ" />
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <CTABand
    eyebrow={wisetackLive ? 'Ready to check your rate?' : 'Financing is part of your estimate conversation.'}
    headline={wisetackLive ? 'Check your rate — no credit score impact' : 'Get your estimate — and ask about spreading the cost over time.'}
    ctaText={wisetackLive ? 'Check my rate' : 'Ask about financing'}
    ctaHref={wisetackLive ? '#check-rate' : '/#estimate'}
    bgImage={cld('projects/malden-cabinet-01-after', 1400)}
  />

  <Footer />
</Base>

<style>
  /* ── Breadcrumb ─────────────────────────────────────── */
  .hero-financing :global(.breadcrumb-list) { color: rgba(247,243,234,0.45); margin-bottom: 20px; }
  .hero-financing :global(.breadcrumb-item a) { color: var(--gold); }
  .hero-financing :global([aria-current="page"]) { color: rgba(247,243,234,0.72); }
  .hero-financing :global(.sep) { color: rgba(247,243,234,0.3); opacity: 1; }

  /* ── Hero ───────────────────────────────────────────── */
  .hero-financing {
    padding: clamp(52px, 5.5vw, 88px) 0 clamp(64px, 7vw, 104px);
    background: var(--forest);
    color: var(--bone);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero-financing::before {
    content: '%';
    position: absolute;
    right: 2%;
    top: 50%;
    transform: translateY(-55%);
    font-family: var(--font-serif);
    font-size: clamp(160px, 22vw, 320px);
    color: rgba(247,243,234,0.03);
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }
  .fhero-media { position:absolute; inset:0; z-index:0; overflow:hidden; pointer-events:none; }
  .fhero-overlay { position:absolute; inset:0; background:linear-gradient(105deg,rgba(20,36,31,0.90) 0%,rgba(20,36,31,0.78) 55%,rgba(20,36,31,0.58) 100%); }
  :global(.fhero-ph) { position:absolute; inset:0; aspect-ratio:unset; height:100%; border-radius:0; }
  .hero-financing .section-head { position: relative; z-index:1; }
  .hero-financing .eyebrow { color: var(--gold); }
  .hero-financing h1 { color: var(--bone); margin-bottom: 24px; }
  .hero-financing .lede {
    color: rgba(247,243,234,0.75);
    margin: 0 auto 36px;
  }

  /* ── How it works ───────────────────────────────────── */
  .section-steps { background: var(--bone); }
  .steps-with-photo {
    display: grid;
    grid-template-columns: 1fr clamp(260px, 30vw, 400px);
    gap: clamp(40px, 5vw, 80px);
    align-items: center;
  }
  .steps-photo {
    border-radius: 3px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(20,36,31,0.12);
  }
  .steps-photo img { width: 100%; height: auto; display: block; }
  @media (max-width: 860px) {
    .steps-with-photo { grid-template-columns: 1fr; }
    .steps-photo { max-width: 480px; }
  }
  .steps-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 0;
    align-items: start;
    margin-top: clamp(40px, 5vw, 64px);
  }
  .step {
    background: var(--bone-deep);
    border: 1px solid var(--line);
    border-radius: 3px;
    padding: clamp(24px, 3.5vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .step-num {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 3.5vw, 3.25rem);
    color: rgba(200,160,85,0.25);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .step h3 { color: var(--forest); }
  .step p { font-size: 0.9375rem; color: var(--text-muted); line-height: 1.72; margin: 0; }

  .step-connector {
    width: 40px;
    height: 2px;
    background: var(--line);
    margin-top: clamp(50px, 6vw, 72px);
    flex-shrink: 0;
  }

  /* ── Widget section ─────────────────────────────────── */
  .section-widget {
    background: var(--bone-deep);
    padding: clamp(64px, 7vw, 104px) 0;
  }
  .widget-wrap {
    max-width: 640px;
    margin: 0 auto;
  }

  /* ── Illustrative examples ──────────────────────────── */
  .section-examples { background: var(--bone); }
  .examples-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 3px;
    overflow: hidden;
    margin-top: clamp(40px, 5vw, 64px);
    position: relative;
  }
  .example-card {
    background: var(--bone);
    padding: clamp(28px, 4vw, 48px) clamp(24px, 3vw, 36px);
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
  }
  .example-card-featured {
    background: var(--forest);
    color: var(--bone);
  }
  /* ── Tier card photo thumb ──────────────────────── */
  .ec-thumb { border-radius:3px; overflow:hidden; margin-bottom:20px; }
  :global(.ec-thumb .ph) { border-radius:3px; }

  .ec-pop-label {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: var(--font-sans);
    background: var(--gold);
    color: var(--ink, #14241F);
    padding: 4px 12px;
    border-radius: 0 0 3px 3px;
    white-space: nowrap;
  }
  .ec-range {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: var(--font-sans);
    color: var(--gold-deep);
    margin-top: 16px;
  }
  .example-card-featured .ec-range { color: var(--gold); }
  .ec-project {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
  }
  .example-card-featured .ec-project { color: rgba(247,243,234,0.6); }
  .ec-amount {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 2.8vw, 2.5rem);
    color: var(--forest);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-top: 8px;
  }
  .example-card-featured .ec-amount { color: var(--bone); }
  .ec-divider {
    height: 1px;
    background: var(--line);
    margin: 12px 0;
  }
  .example-card-featured .ec-divider { background: rgba(247,243,234,0.12); }
  .ec-payment {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .ec-from {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
  }
  .example-card-featured .ec-from { color: rgba(247,243,234,0.55); }
  .ec-monthly {
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 2.2vw, 1.875rem);
    color: var(--forest);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .example-card-featured .ec-monthly { color: var(--gold); }
  .ec-per {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
  }
  .example-card-featured .ec-per { color: rgba(247,243,234,0.55); }
  .ec-note {
    font-size: 10px;
    color: var(--text-muted);
    font-family: var(--font-sans);
    letter-spacing: 0.01em;
    margin-top: 8px;
    line-height: 1.5;
  }
  .example-card-featured .ec-note { color: rgba(247,243,234,0.4); }
  .examples-disclaimer {
    margin-top: 20px;
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.65;
    max-width: 72ch;
  }

  /* ── Mini-FAQ ───────────────────────────────────────── */
  .section-financing-faq { background: var(--bone-deep); }
  .faq-wrap { max-width: 720px; }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 900px) {
    .steps-row {
      grid-template-columns: 1fr;
    }
    .step-connector {
      width: 2px;
      height: 32px;
      margin: 0 auto;
    }
    .examples-grid { grid-template-columns: 1fr; }
    .ec-pop-label {
      top: auto;
      bottom: -1px;
      border-radius: 3px 3px 0 0;
    }
  }
</style>
