---
import projectsData from '../../../data/projects.json';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABand from '../../components/CTABand.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SchemaLD from '../../components/SchemaLD.astro';
import PlaceholderImage from '../../components/PlaceholderImage.astro';
import BeforeAfter from '../../components/BeforeAfter.astro';

// ── Process step metadata — mirrors homepage processSteps ──────────────────
const PROCESS_STEPS = [
  { num: '01', slug: 'video-walkthrough', title: 'Video walkthrough' },
  { num: '02', slug: 'prep-containment',  title: 'Prep & containment' },
  { num: '03', slug: 'hand-sand',         title: 'Surface prep & repair' },
  { num: '04', slug: 'spray-finish',      title: 'Finish & installation' },
  { num: '05', slug: 'cure-walkthrough',  title: 'Cure & walkthrough' },
];

// ── Cloudinary helper ─────────────────────────────────────────────────────
const cloud = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? 'dxuuydoee';
const CLD = `https://res.cloudinary.com/${cloud}/image/upload`;

// ── getStaticPaths ────────────────────────────────────────────────────────
export async function getStaticPaths() {
  return projectsData.projects.map(p => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

// ── Types ─────────────────────────────────────────────────────────────────
interface GalleryPhoto { src: string; alt: string; }
interface Project {
  slug: string;
  client: string;
  location: string;
  projectType: string;
  headline: string;
  ctaHeadline: string;
  beforeAfterH2: string;
  scope: string[];
  timeline: string;
  finish: string;
  investment: { display: string; note: string; };
  result: string;
  challenge: string;
  testimonial: { name: string; quote: string; headshotSrc: string; };
  heroPublicId: string;
  heroAlt: string;
  beforePublicId: string;
  afterPublicId: string;
  beforeAlt: string;
  afterAlt: string;
  galleryPhotos: GalleryPhoto[];
  processNotes: Record<string, string>;
  returningClient?: boolean;
}
interface Props { project: Project }

const { project } = Astro.props;
const {
  client, location, projectType, headline, ctaHeadline, beforeAfterH2, scope, timeline, finish,
  investment, result, challenge, testimonial, heroPublicId, heroAlt,
  beforePublicId, afterPublicId, beforeAlt, afterAlt,
  galleryPhotos, processNotes, returningClient,
} = project;

// ── Page meta ─────────────────────────────────────────────────────────────
const title = `${headline} — Project by Jerry & Co. in ${location}`;
const metaDesc = `${result} See the before & after, our process in practice, and the client's own words. Free estimates for ${location.split(',')[0]} and Greater Boston.`;
const canonical = `https://www.jerryandcohome.com/projects/${project.slug}/`;
const ogImage = `${CLD}/f_auto,q_auto,w_1200,h_630,c_fill/${heroPublicId}.jpg`;

// ── Schemas ───────────────────────────────────────────────────────────────
const reviewSchema = {
  itemReviewed: {
    '@type': 'LocalBusiness',
    name: 'Jerry & Co. Home Improvement LLC',
  },
  reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
  author: { '@type': 'Person', name: testimonial.name },
  reviewBody: testimonial.quote,
};

const breadcrumbSchema = {
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',     item: 'https://www.jerryandcohome.com/' },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: 'https://www.jerryandcohome.com/projects/' },
    { '@type': 'ListItem', position: 3, name: client,     item: canonical },
  ],
};

const town = location.split(',')[0];
---

<Base title={title} description={metaDesc} canonical={canonical} ogImage={ogImage}>
  <Fragment slot="head">
    <SchemaLD type="Review" data={reviewSchema} />
    <SchemaLD type="BreadcrumbList" data={breadcrumbSchema} />
  </Fragment>

  <Header />

  <!-- ══════════════════════════════════════════════════════════
       SECTION 1 — HERO
  ══════════════════════════════════════════════════════════ -->
  <section class="proj-hero">
    <div class="proj-hero-media" aria-hidden="true">
      <PlaceholderImage
        publicId={heroPublicId}
        alt={heroAlt}
        aspect="16/9"
        loading="eager"
        fetchpriority="high"
        className="proj-hero-ph"
      />
      <div class="proj-hero-overlay"></div>
    </div>
    <div class="wrap proj-hero-inner">
      <Breadcrumb crumbs={[
        { label: 'Home',     href: '/' },
        { label: 'Projects', href: '/projects/' },
        { label: client },
      ]} />
      <div class="proj-hero-chips">
        <span class="proj-chip">{projectType}</span>
        <span class="proj-chip proj-chip-loc">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 1.5C5.51 1.5 3.5 3.51 3.5 6c0 3.75 4.5 8.5 4.5 8.5s4.5-4.75 4.5-8.5c0-2.49-2.01-4.5-4.5-4.5z"/><circle cx="8" cy="6" r="1.5"/></svg>
          {location}
        </span>
      </div>
      <h1>{headline}</h1>
      <a class="proj-hero-anchor" href="#result">
        See the result
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M8 3v10M4 9l4 4 4-4"/></svg>
      </a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       SECTION 2 — FAST FACTS
  ══════════════════════════════════════════════════════════ -->
  <div class="proj-facts-strip" data-reveal="up">
    <div class="wrap proj-facts-inner">
      <div class="proj-fact">
        <span class="pf-label">Timeline</span>
        <span class="pf-value">{timeline}</span>
      </div>
      <div class="pf-sep" aria-hidden="true"></div>
      <div class="proj-fact">
        <span class="pf-label">Scope</span>
        <span class="pf-value">{scope.join(' · ')}</span>
      </div>
      <div class="pf-sep" aria-hidden="true"></div>
      <div class="proj-fact">
        <span class="pf-label">Finish</span>
        <span class="pf-value">{finish}</span>
      </div>
      <div class="pf-sep" aria-hidden="true"></div>
      <div class="proj-fact proj-fact-invest">
        <span class="pf-label">Investment</span>
        <span class="pf-value pf-invest-num">{investment.display}</span>
        <span class="pf-invest-note">{investment.note}</span>
      </div>
      <div class="pf-sep" aria-hidden="true"></div>
      <div class="proj-fact">
        <span class="pf-label">Location</span>
        <span class="pf-value">{location}</span>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       SECTION 3 — THE CHALLENGE
  ══════════════════════════════════════════════════════════ -->
  <section class="proj-challenge">
    <div class="wrap proj-challenge-inner">
      <div class="proj-challenge-text" data-reveal="left">
        <p class="eyebrow">What they needed</p>
        <h2>The challenge</h2>
        <p class="challenge-body">{challenge}</p>
      </div>
      <div class="proj-challenge-img" data-reveal="right" data-delay="2">
        <PlaceholderImage
          publicId={beforePublicId}
          alt={beforeAlt}
          aspect="4/3"
          loading="lazy"
          caption="Before"
        />
        <span class="img-label-pill">Before</span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       SECTION 4 — PROCESS IN PRACTICE
  ══════════════════════════════════════════════════════════ -->
  <section class="proj-process">
    <div class="wrap">
      <div class="section-head" data-reveal="up">
        <p class="eyebrow">How it happened — step by step.</p>
        <h2>How your kitchen gets this result.</h2>
        <p class="section-lede-center">The same five-stage process, applied to this project.</p>
      </div>
      <div class="proj-process-grid">
        {PROCESS_STEPS.map((step, i) => (
          <div class="pp-card" data-reveal="up" data-delay={String(i + 1)}>
            <div class="pp-num">{step.num}</div>
            <h3 class="pp-title">{step.title}</h3>
            <p class="pp-note">{processNotes[step.slug] ?? 'Details to be added.'}</p>
          </div>
        ))}
      </div>
      <div class="proj-process-foot">
        <a href="/our-process/" class="btn btn-outline">See the full process →</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       SECTION 5 — BEFORE & AFTER + GALLERY
  ══════════════════════════════════════════════════════════ -->
  <section class="proj-ba" id="result">
    <div class="wrap">
      <div class="section-head" data-reveal="up">
        <p class="eyebrow">The transformation</p>
        <h2>{beforeAfterH2}</h2>
      </div>
      <div class="proj-ba-slider" data-reveal="scale">
        <BeforeAfter
          beforeSrc={`${CLD}/f_auto,q_auto,w_1600/${beforePublicId}.jpg`}
          afterSrc={`${CLD}/f_auto,q_auto,w_1600/${afterPublicId}.jpg`}
          beforeAlt={beforeAlt}
          afterAlt={afterAlt}
          caption={`${client} · ${location} — drag to compare`}
        />
      </div>
      {galleryPhotos.length > 0 && (
        <div class="proj-gallery" data-reveal="in" data-delay="2">
          {galleryPhotos.map(photo => (
            <div class="proj-gallery-cell">
              <img
                src={photo.src}
                alt={photo.alt}
                loading="lazy"
                decoding="async"
                onerror="this.style.opacity='0'"
              />
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       SECTION 6 — THE RESULT
  ══════════════════════════════════════════════════════════ -->
  <section class="proj-result">
    <div class="wrap proj-result-inner">

      <div class="proj-result-left">
        <p class="eyebrow">The result</p>
        <blockquote class="proj-result-pull">{result}</blockquote>
        <div class="proj-invest-callout">
          <span class="pic-num">{investment.display}</span>
          <span class="pic-note">{investment.note}</span>
        </div>
      </div>

      <div class="proj-result-right">
        <div class="proj-testimonial" data-reveal="up">
          <svg class="proj-quote-mark" viewBox="0 0 40 32" fill="none" aria-hidden="true">
            <path d="M0 32V19.2C0 8.533 5.333 2.133 16 0l2.4 3.2C12.267 4.8 8.8 8.533 8 14.4H16V32H0zm24 0V19.2C24 8.533 29.333 2.133 40 0l2.4 3.2C36.267 4.8 32.8 8.533 32 14.4H40V32H24z" fill="currentColor"/>
          </svg>
          <p class="proj-testimonial-quote">{testimonial.quote}</p>
          <div class="proj-testimonial-attr">
            <img
              src={testimonial.headshotSrc}
              alt={testimonial.name}
              class="proj-headshot"
              width="52"
              height="52"
              loading="lazy"
              decoding="async"
              onerror="this.style.opacity='0'"
            />
            <div>
              <p class="proj-attr-name">{testimonial.name}</p>
              <p class="proj-attr-meta">{projectType} · {location}</p>
              {returningClient && (
                <span class="proj-returning">Returning client</span>
              )}
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       SECTION 7 — CTA BAND
  ══════════════════════════════════════════════════════════ -->
  <CTABand
    eyebrow={`Free video estimate in ${town}`}
    headline={ctaHeadline}
    ctaText="Get my free estimate"
  />

  <Footer />
</Base>

<style>
  /* ── Breadcrumb inside hero ─────────────────────────────── */
  .proj-hero :global(.breadcrumb-list) { color: rgba(247,243,234,0.45); margin-bottom: 16px; }
  .proj-hero :global(.breadcrumb-item a) { color: var(--gold); }
  .proj-hero :global([aria-current="page"]) { color: rgba(247,243,234,0.72); }
  .proj-hero :global(.sep) { color: rgba(247,243,234,0.3); opacity: 1; }

  /* ══════════════════════════════════════════════════════════
     HERO
  ══════════════════════════════════════════════════════════ */
  .proj-hero {
    background: var(--forest);
    color: var(--bone);
    padding: clamp(28px, 4vw, 52px) 0 clamp(32px, 4.5vw, 56px);
    position: relative;
    overflow: hidden;
  }
  .proj-hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  :global(.proj-hero-ph) {
    position: absolute;
    inset: 0;
    aspect-ratio: unset;
    height: 100%;
    border-radius: 0;
  }
  .proj-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      108deg,
      rgba(20, 36, 31, 0.94) 0%,
      rgba(20, 36, 31, 0.76) 50%,
      rgba(20, 36, 31, 0.46) 100%
    );
  }
  .proj-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }
  .proj-hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }
  .proj-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--gold);
    border-radius: var(--radius-xs);
    padding: 4px 10px;
  }
  .proj-chip-loc {
    background: rgba(247, 243, 234, 0.12);
    color: rgba(247, 243, 234, 0.8);
  }
  .proj-chip-loc svg { width: 12px; height: 12px; }
  .proj-hero h1 {
    color: var(--bone);
    margin-bottom: 28px;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
  }
  .proj-hero-anchor {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gold);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }
  .proj-hero-anchor:hover { color: var(--bone); }
  .proj-hero-anchor svg { width: 16px; height: 16px; }

  /* ══════════════════════════════════════════════════════════
     FAST FACTS
  ══════════════════════════════════════════════════════════ */
  .proj-facts-strip {
    background: var(--bone-deep);
    border-bottom: 1px solid var(--line);
    padding: 0;
  }
  .proj-facts-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 0;
  }
  .proj-fact {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    padding: 22px 28px;
    flex: 1;
    min-width: 130px;
  }
  .pf-sep {
    width: 1px;
    background: var(--line);
    align-self: stretch;
  }
  .pf-label {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .pf-value {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--forest);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .proj-fact-invest { flex: 1.4; }
  .pf-invest-num {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--forest);
  }
  .pf-invest-note {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--text-muted);
    line-height: 1.4;
    margin-top: 2px;
  }

  /* ══════════════════════════════════════════════════════════
     CHALLENGE
  ══════════════════════════════════════════════════════════ */
  .proj-challenge {
    background: var(--bone);
    padding: clamp(64px, 8vw, 104px) 0;
  }
  .proj-challenge-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-7);
    align-items: center;
  }
  .proj-challenge-text h2 { margin-bottom: 20px; }
  .challenge-body {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.78;
    max-width: 52ch;
    margin: 0;
  }
  .proj-challenge-img { position: relative; }
  .img-label-pill {
    position: absolute;
    top: 14px;
    left: 14px;
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bone);
    background: rgba(20, 36, 31, 0.6);
    backdrop-filter: blur(4px);
    border-radius: var(--radius-xs);
    padding: 4px 10px;
    pointer-events: none;
  }

  /* ══════════════════════════════════════════════════════════
     PROCESS IN PRACTICE
  ══════════════════════════════════════════════════════════ */
  .proj-process {
    background: var(--ink);
    color: var(--bone);
    padding: clamp(64px, 8vw, 104px) 0;
  }
  .proj-process .section-head h2 { color: var(--bone); }
  .proj-process .section-lede-center { color: rgba(247, 243, 234, 0.55); }
  .proj-process-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: rgba(247, 243, 234, 0.08);
    border: 1px solid rgba(247, 243, 234, 0.08);
    border-radius: var(--radius-sm);
    overflow: hidden;
    margin-top: var(--sp-5);
  }
  .pp-card {
    background: var(--ink-soft);
    padding: clamp(24px, 2.5vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
    justify-content: flex-start;
  }
  .pp-num {
    font-family: var(--font-serif);
    font-size: 2rem;
    color: var(--gold);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .pp-title {
    font-size: 0.9375rem;
    color: var(--bone);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0;
  }
  .pp-note {
    font-size: 13px;
    color: rgba(247, 243, 234, 0.5);
    line-height: 1.65;
    margin: 0;
    margin-top: auto;
  }
  .proj-process-foot {
    margin-top: var(--sp-5);
    text-align: center;
  }

  /* ══════════════════════════════════════════════════════════
     BEFORE & AFTER + GALLERY
  ══════════════════════════════════════════════════════════ */
  .proj-ba {
    background: var(--bone-deep);
    padding: clamp(64px, 8vw, 104px) 0;
  }
  .proj-ba-slider {
    max-width: 820px;
    margin: var(--sp-5) auto 0;
  }
  .proj-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius-xs);
    overflow: hidden;
    margin-top: var(--sp-3);
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
  }
  .proj-gallery-cell {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--bone-deep);
  }
  .proj-gallery-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .proj-gallery-cell:hover img { transform: scale(1.03); }

  /* ══════════════════════════════════════════════════════════
     RESULT
  ══════════════════════════════════════════════════════════ */
  .proj-result {
    background: var(--bone);
    padding: clamp(64px, 8vw, 104px) 0;
  }
  .proj-result-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-7);
    align-items: start;
  }
  .proj-result-pull {
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 2.2vw, 1.875rem);
    color: var(--forest);
    line-height: 1.3;
    letter-spacing: -0.025em;
    margin: 0 0 var(--sp-4);
    padding: 0;
    border: none;
    font-style: italic;
  }
  .proj-invest-callout {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--sp-3);
    background: var(--bone-deep);
    border: 1px solid var(--line);
    border-left: 3px solid var(--gold);
    border-radius: var(--radius-xs);
  }
  .pic-num {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--forest);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .pic-note {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* Testimonial card */
  .proj-testimonial {
    background: var(--bone-deep);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: clamp(28px, 3.5vw, 44px);
    position: relative;
  }
  .proj-quote-mark {
    width: 28px;
    height: auto;
    color: var(--gold);
    opacity: 0.5;
    margin-bottom: 16px;
  }
  .proj-testimonial-quote {
    font-size: 1.0625rem;
    color: var(--text);
    line-height: 1.72;
    margin: 0 0 24px;
    font-style: italic;
  }
  .proj-testimonial-attr {
    display: flex;
    align-items: center;
    gap: 14px;
    border-top: 1px solid var(--line);
    padding-top: 20px;
  }
  .proj-headshot {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--bone-deep);
    border: 2px solid var(--line);
    color: transparent;
  }
  .proj-attr-name {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--forest);
    margin: 0;
  }
  .proj-attr-meta {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--text-muted);
    margin: 3px 0 0;
    letter-spacing: 0.01em;
  }
  .proj-returning {
    display: inline-block;
    margin-top: 6px;
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--gold-deep);
