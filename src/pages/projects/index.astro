---
import projectsData from '../../../data/projects.json';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABand from '../../components/CTABand.astro';
import SchemaLD from '../../components/SchemaLD.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const projects = projectsData.projects;

const title = 'Our Work — Cabinet Refinishing & Bathroom Projects | Jerry & Co.';
const metaDesc = 'Real projects, real results. Browse cabinet refinishing and bathroom renovations completed by Jerry & Co. in Charlestown, Boston, and Somerville, MA.';
const canonical = 'https://www.jerryandcohome.com/projects/';

const breadcrumbSchema = {
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',     item: 'https://www.jerryandcohome.com/' },
    { '@type': 'ListItem', position: 2, name: 'Projects', item: canonical },
  ],
};
---

<Base title={title} description={metaDesc} canonical={canonical}>
  <Fragment slot="head">
    <SchemaLD type="BreadcrumbList" data={breadcrumbSchema} />
  </Fragment>

  <Header />

  <!-- ── Page header ─────────────────────────────────────── -->
  <section class="proj-index-hero">
    <div class="wrap">
      <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Projects' }]} />
      <p class="eyebrow" data-reveal="up">Real kitchens. Real clients. Real numbers.</p>
      <h1 data-reveal="up" data-delay="1">Real kitchens across Greater Boston — before and after.</h1>
      <p class="proj-index-lede">5 real projects. Real clients. Real numbers — from $6,800 to $13,500. No composites, no stock photos.</p>
    </div>
  </section>

  <!-- ── Project grid ────────────────────────────────────── -->
  <section class="proj-index-grid-section">
    <div class="wrap">
      <div class="proj-index-grid">
        {projects.map((p, i) => (
          <a class="proj-card" href={`/projects/${p.slug}/`} data-reveal="scale" data-delay={String(i + 1)}>
            <div class="proj-card-top">
              <div class="proj-card-top-start">
                <span class="proj-card-type">{p.projectType}</span>
                {(p as any).returningClient && (
                  <span class="proj-card-returning">Returning client</span>
                )}
              </div>
              <span class="proj-card-loc">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 1.5C5.51 1.5 3.5 3.51 3.5 6c0 3.75 4.5 8.5 4.5 8.5s4.5-4.75 4.5-8.5c0-2.49-2.01-4.5-4.5-4.5z"/><circle cx="8" cy="6" r="1.5"/></svg>
                {p.location}
              </span>
            </div>
            <div class="proj-card-photos">
              {p.galleryPhotos.slice(0, 3).map((photo) => (
                <div class="proj-card-photo">
                  <img
                    src={photo.src}
                    alt={photo.alt.startsWith('PLACEHOLDER') ? `${p.client} project — ${p.location}` : photo.alt}
                    loading="lazy"
                    decoding="async"
                    onerror="this.style.opacity='0'"
                  />
                </div>
              ))}
            </div>
            <div class="proj-card-body">
              <h2 class="proj-card-headline">
                {p.headline.startsWith('PLACEHOLDER') ? `${p.client} — ${p.location}` : p.headline}
              </h2>
              <p class="proj-card-meta">
                <span>{p.timeline.startsWith('PLACEHOLDER') ? 'See full project' : p.timeline}</span>
                {!p.investment.display.startsWith('PLACEHOLDER') && (
                  <>
                    <span class="proj-card-dot" aria-hidden="true">·</span>
                    <span class="proj-card-invest">{p.investment.display}</span>
                  </>
                )}
              </p>
              <span class="proj-card-cta">
                View the project
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Trust note ──────────────────────────────────────── -->
  <section class="proj-index-trust">
    <div class="wrap proj-index-trust-inner">
      <div class="pit-item">
        <strong>MA HIC #208336</strong>
        <span>Licensed &amp; insured</span>
      </div>
      <div class="pit-sep" aria-hidden="true"></div>
      <div class="pit-item">
        <strong>100% low-VOC</strong>
        <span>Safe for occupied units</span>
      </div>
      <div class="pit-sep" aria-hidden="true"></div>
      <div class="pit-item">
        <strong>Jeremiah on every project</strong>
        <span>No subs, no handoffs</span>
      </div>
      <div class="pit-sep" aria-hidden="true"></div>
      <div class="pit-item pit-item-cta">
        <a href="/#estimate" class="btn">Get a free estimate</a>
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Free video estimate"
    headline="Your kitchen. Written quote. 24 hours."
    ctaText="Get my free estimate"
  />

  <Footer />
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .proj-index-hero {
    background: var(--bone-deep);
    border-bottom: 1px solid var(--line);
    padding: clamp(36px, 4.5vw, 68px) 0 clamp(40px, 5vw, 64px);
  }
  .proj-index-hero h1 { margin-bottom: 16px; }
  .proj-index-lede {
    max-width: 58ch;
    color: var(--text-muted);
    font-size: 1.0625rem;
    line-height: 1.72;
    margin: 0;
  }

  /* ── Grid section ─────────────────────────────────────── */
  .proj-index-grid-section {
    background: var(--bone);
    padding: clamp(56px, 7vw, 88px) 0;
  }
  .proj-index-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-5);
  }

  /* ── Project card ─────────────────────────────────────── */
  .proj-index-hero :global(.breadcrumb-list) { color: rgba(30,57,52,0.45); margin-bottom: 20px; }
  .proj-index-hero :global(.breadcrumb-item a) { color: var(--gold-deep); }
  .proj-index-hero :global([aria-current="page"]) { color: var(--text-muted); }

  .proj-card {
    display: flex;
    flex-direction: column;
    background: var(--bone-deep);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.22s cubic-bezier(0.22, 1, 0.36, 1), transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .proj-card:hover {
    box-shadow: 0 14px 40px rgba(20, 36, 31, 0.13);
    transform: translateY(-5px);
  }
  .proj-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--line);
    flex-wrap: wrap;
  }
  .proj-card-top-start {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
  }
  .proj-card-type {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .proj-card-returning {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--gold-deep);
    border: 1px solid rgba(200, 160, 85, 0.38);
    border-radius: 3px;
    padding: 2px 6px;
    white-space: nowrap;
  }
  .proj-card-loc {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }
  .proj-card-loc svg { width: 11px; height: 11px; flex-shrink: 0; }

  /* Photo strip */
  .proj-card-photos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    aspect-ratio: 3 / 1;
  }
  .proj-card-photo {
    overflow: hidden;
    background: var(--bone-deep);
  }
  .proj-card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .proj-card:hover .proj-card-photo img { transform: scale(1.04); }

  /* Card body */
  .proj-card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px 22px 20px;
    flex: 1;
  }
  .proj-card-headline {
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    color: var(--forest);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .proj-card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--text-muted);
    margin: 0;
    letter-spacing: 0.01em;
  }
  .proj-card-dot { color: var(--line); }
  .proj-card-invest {
    font-weight: 600;
    color: var(--forest);
  }
  .proj-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: auto;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--gold-deep);
    padding-top: 4px;
    transition: color 0.15s;
  }
  .proj-card-cta svg { width: 13px; height: 13px; flex-shrink: 0; transition: transform 0.15s; }
  .proj-card:hover .proj-card-cta { color: var(--forest); }
  .proj-card:hover .proj-card-cta svg { transform: translateX(3px); }

  /* ── Trust strip ──────────────────────────────────────── */
  .proj-index-trust {
    background: var(--bone-deep);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 0;
  }
  .proj-index-trust-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }
  .pit-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 20px 28px;
    flex: 1;
    min-width: 150px;
  }
  .pit-item strong {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    color: var(--forest);
    letter-spacing: -0.02em;
    font-weight: 500;
  }
  .pit-item span {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }
  .pit-sep {
    width: 1px;
    height: 40px;
    background: var(--line);
    flex-shrink: 0;
  }
  .pit-item-cta {
    flex: 0;
    min-width: auto;
    padding: 20px 28px;
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 768px) {
    .proj-index-grid { grid-template-columns: 1fr; }
    .pit-sep { display: none; }
    .pit-item { border-bottom: 1px solid var(--line); min-width: 100%; }
    .pit-item:last-child { border-bottom: none; }
    .pit-item-cta { padding: 20px 28px; }
  }
</style>
