---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaLD from '../components/SchemaLD.astro';
import Quiz from '../components/Quiz.astro';

const title = 'Is Cabinet Refinishing Right for You? | Jerry & Co. Boston';
const description =
  'Answer 6 quick questions — we\'ll tell you if cabinet refinishing makes sense for your home and what to expect from the process.';
const canonical = 'https://www.jerryandcohomeservices.com/cabinet-quiz/';

const breadcrumbSchema = {
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',         item: 'https://www.jerryandcohomeservices.com/' },
    { '@type': 'ListItem', position: 2, name: 'Cabinet Quiz', item: canonical },
  ],
};
---

<Base title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <SchemaLD type="BreadcrumbList" data={breadcrumbSchema} />
  </Fragment>

  <Header />

  <!-- ===== BREADCRUMB ===== -->
  <div class="wrap breadcrumb-wrap">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Cabinet Quiz' }]} />
  </div>

  <!-- ===== PAGE HEADER ===== -->
  <section class="quiz-page-header">
    <div class="wrap">
      <div class="qph-inner">
        <div class="qph-text">
          <p class="eyebrow">2-minute self-assessment</p>
          <h1>Is cabinet refinishing right for your home?</h1>
          <p class="lede">
            Answer 6 quick questions — we'll tell you if refinishing makes sense
            and what to expect from the process.
          </p>
          <div class="qph-trust">
            <span class="trust-chip">No email required</span>
            <span class="trust-chip">Instant result</span>
            <span class="trust-chip">Honest assessment</span>
          </div>
        </div>
        <div class="qph-aside">
          <div class="qph-stat-card">
            <span class="qph-stat-num">~2 min</span>
            <span class="qph-stat-label">to complete</span>
          </div>
          <div class="qph-stat-card">
            <span class="qph-stat-num">6</span>
            <span class="qph-stat-label">questions</span>
          </div>
          <div class="qph-stat-card">
            <span class="qph-stat-num">3</span>
            <span class="qph-stat-label">possible outcomes</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== QUIZ ISLAND ===== -->
  <section class="quiz-section">
    <div class="wrap quiz-wrap">
      <Quiz />
    </div>
  </section>

  <!-- ===== CONTEXT STRIP ===== -->
  <section class="quiz-context-strip">
    <div class="wrap context-inner">
      <div class="context-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>
        </svg>
        <div>
          <strong>We'll be honest</strong>
          <p>If refinishing isn't the right call for your cabinets, we'll tell you upfront — not after you've paid a deposit.</p>
        </div>
      </div>
      <div class="context-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/>
        </svg>
        <div>
          <strong>Free video estimate follows</strong>
          <p>Quiz result maps directly to your estimate form — no re-entering answers. We pick up where this left off.</p>
        </div>
      </div>
      <div class="context-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <div>
          <strong>Owner answers every quote</strong>
          <p>Jeremiah reviews every quiz lead personally. Not a call center — the person who will do the work gives the estimate.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* ── Breadcrumb ─────────────────────────────────────── */
  .breadcrumb-wrap { padding-top: 24px; }

  /* ── Page header ────────────────────────────────────── */
  .quiz-page-header {
    background: var(--forest);
    color: var(--bone);
    padding: clamp(60px, 8vw, 100px) 0 clamp(48px, 6vw, 72px);
  }
  .qph-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  .qph-text .eyebrow { color: var(--gold); }
  .qph-text h1 { color: var(--bone); margin-bottom: 16px; }
  .qph-text .lede { color: rgba(247,243,234,0.75); margin-bottom: 24px; }

  .qph-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .trust-chip {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(247,243,234,0.6);
    border: 1px solid rgba(247,243,234,0.2);
    border-radius: 2px;
    padding: 4px 10px;
    letter-spacing: 0.02em;
  }

  /* Stat cards aside */
  .qph-aside {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-shrink: 0;
  }
  .qph-stat-card {
    background: rgba(247,243,234,0.06);
    border: 1px solid rgba(247,243,234,0.12);
    border-radius: 3px;
    padding: 14px 20px;
    display: flex;
    align-items: baseline;
    gap: 10px;
    min-width: 140px;
  }
  .qph-stat-num {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--gold);
    letter-spacing: -0.04em;
    line-height: 1;
    white-space: nowrap;
  }
  .qph-stat-label {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: rgba(247,243,234,0.55);
    line-height: 1.3;
  }

  /* ── Quiz section ───────────────────────────────────── */
  .quiz-section {
    background: var(--bone-deep);
    padding: clamp(56px, 7vw, 96px) 0;
  }
  .quiz-wrap {
    max-width: 740px;
    margin: 0 auto;
  }

  /* ── Context strip ──────────────────────────────────── */
  .quiz-context-strip {
    background: var(--bone);
    border-top: 1px solid var(--line);
    padding: clamp(40px, 5vw, 64px) 0;
  }
  .context-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 4vw, 48px);
  }
  .context-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .context-item svg {
    width: 24px;
    height: 24px;
    color: var(--gold-deep);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .context-item strong {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--forest);
    margin-bottom: 6px;
  }
  .context-item p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 768px) {
    .qph-inner { grid-template-columns: 1fr; }
    .qph-aside { flex-direction: row; flex-wrap: wrap; }
    .qph-stat-card { min-width: unset; flex: 1; }
    .context-inner { grid-template-columns: 1fr; }
  }
</style>
