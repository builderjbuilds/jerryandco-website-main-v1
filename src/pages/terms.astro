---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = 'Terms of Service | Jerry & Co. Home Improvement LLC';
const description = 'Terms governing your use of the Jerry & Co. Home Improvement LLC website, estimate request forms, and related services.';
const canonical = 'https://www.jerryandcohome.com/terms/';
const EFFECTIVE = 'July 1, 2026';
---

<Base title={title} description={description} canonical={canonical}>
  <Header />

  <section class="legal-hero">
    <div class="wrap">
      <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Terms of Service' }]} />
      <p class="eyebrow">Legal</p>
      <h1>Terms of Service</h1>
      <p class="legal-meta">Effective date: {EFFECTIVE} &nbsp;·&nbsp; Jerry &amp; Co. Home Improvement LLC &nbsp;·&nbsp; Greater Boston, MA</p>
    </div>
  </section>

  <section class="legal-body">
    <div class="wrap legal-wrap">

      <div class="legal-toc">
        <p class="toc-head">On this page</p>
        <ol>
          <li><a href="#agreement">Agreement to terms</a></li>
          <li><a href="#who-we-are">Who we are</a></li>
          <li><a href="#the-site">The website</a></li>
          <li><a href="#estimates">Estimate requests</a></li>
          <li><a href="#ip">Intellectual property</a></li>
          <li><a href="#acceptable-use">Acceptable use</a></li>
          <li><a href="#third-party-links">Third-party links</a></li>
          <li><a href="#disclaimer">Disclaimers</a></li>
          <li><a href="#liability">Limitation of liability</a></li>
          <li><a href="#indemnification">Indemnification</a></li>
          <li><a href="#governing-law">Governing law</a></li>
          <li><a href="#changes">Changes to terms</a></li>
          <li><a href="#contact">Contact us</a></li>
        </ol>
      </div>

      <div class="legal-prose">

        <h2 id="agreement">1. Agreement to terms</h2>
        <p>These Terms of Service ("Terms") govern your access to and use of the website located at <strong>jerryandcohome.com</strong> (the "Site"), operated by Jerry &amp; Co. Home Improvement LLC ("Jerry &amp; Co.," "we," "us," or "our").</p>
        <p>By accessing or using the Site — including submitting an estimate request, subscribing to our newsletter, or simply browsing — you agree to be bound by these Terms. If you do not agree, please stop using the Site immediately.</p>
        <p>These Terms apply alongside our <a href="/privacy/">Privacy Policy</a>, which is incorporated by reference.</p>

        <h2 id="who-we-are">2. Who we are</h2>
        <p>Jerry &amp; Co. Home Improvement LLC is a Massachusetts-based home improvement contractor licensed under <strong>MA Home Improvement Contractor Registration #208336</strong>. We specialize in cabinet refinishing, bathroom refresh, and interior painting services for condo owners, homeowners, and property managers across Greater Boston.</p>
        <p>All in-unit work is performed by the owner, Jeremiah Ugbine, or under his direct supervision.</p>

        <h2 id="the-site">3. The website</h2>
        <p>The Site is an informational and lead-generation website. It is designed to:</p>
        <ul>
          <li>Provide information about our services, pricing ranges, process, and service areas</li>
          <li>Allow visitors to submit project estimate requests</li>
          <li>Facilitate communication between prospective clients and Jerry &amp; Co.</li>
        </ul>
        <p>The Site is not a marketplace, booking platform, or binding contract mechanism. Submitting a form does not create a service agreement or guarantee availability.</p>

        <h2 id="estimates">4. Estimate requests</h2>
        <p>When you submit an estimate request through the Site:</p>
        <ul>
          <li>You are requesting that we review your project details and contact you to discuss a potential engagement</li>
          <li>No service agreement, contract, or binding obligation is created between you and Jerry &amp; Co. by submitting a form</li>
          <li>Any price ranges displayed on the Site are illustrative only and do not constitute a quote or binding offer</li>
          <li>A written, fixed-price estimate will be provided separately following a video or in-person consultation, at which point pricing becomes binding only when both parties execute a written agreement</li>
          <li>We reserve the right to decline any project at our discretion</li>
        </ul>

        <h2 id="ip">5. Intellectual property</h2>
        <p>All content on the Site — including but not limited to text, photography, graphics, logos, trade names, and copy — is owned by or licensed to Jerry &amp; Co. Home Improvement LLC and is protected by applicable United States and Massachusetts intellectual property laws.</p>
        <p>You may view and print pages from the Site for personal, non-commercial use only. You may not reproduce, republish, distribute, sell, or create derivative works from any Site content without our prior written permission.</p>
        <p>The Jerry &amp; Co. name, logo, and tagline are proprietary to Jerry &amp; Co. Home Improvement LLC. Nothing on the Site grants a license to use our trademarks.</p>

        <h2 id="acceptable-use">6. Acceptable use</h2>
        <p>You agree not to use the Site to:</p>
        <ul>
          <li>Submit false, misleading, or fraudulent information in any form</li>
          <li>Attempt to gain unauthorized access to any portion of the Site or its underlying systems</li>
          <li>Transmit malware, viruses, or other harmful code</li>
          <li>Scrape, crawl, or data-mine the Site's content without express written permission</li>
          <li>Impersonate Jerry &amp; Co. or any employee, contractor, or representative</li>
          <li>Use the Site in any manner that violates applicable federal, state, or local law</li>
          <li>Engage in any conduct that disrupts, interferes with, or imposes an unreasonable burden on the Site or its servers</li>
        </ul>
        <p>We reserve the right to block access to the Site from any user or IP address that violates these terms.</p>

        <h2 id="third-party-links">7. Third-party links</h2>
        <p>The Site may contain links to third-party websites (such as financing providers, review platforms, or social media). These links are provided for convenience only. Jerry &amp; Co. does not control, endorse, or assume responsibility for the content, privacy practices, or terms of any third-party site. Your use of any third-party site is at your own risk.</p>

        <h2 id="disclaimer">8. Disclaimers</h2>
        <p>THE SITE AND ITS CONTENT ARE PROVIDED ON AN "AS IS" AND "AS AVAILABLE" BASIS WITHOUT WARRANTIES OF ANY KIND, EITHER EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE, OR NON-INFRINGEMENT.</p>
        <p>We do not warrant that:</p>
        <ul>
          <li>The Site will be uninterrupted, error-free, or free of viruses or other harmful components</li>
          <li>The information on the Site is complete, accurate, or current</li>
          <li>Results obtained from using the Site will meet your expectations</li>
        </ul>
        <p>Pricing ranges, timelines, and project descriptions displayed on the Site are examples based on typical projects and do not guarantee the same outcome for any specific project.</p>

        <h2 id="liability">9. Limitation of liability</h2>
        <p>TO THE FULLEST EXTENT PERMITTED BY APPLICABLE LAW, JERRY &amp; CO. HOME IMPROVEMENT LLC, ITS OWNER, EMPLOYEES, AND AGENTS SHALL NOT BE LIABLE FOR ANY INDIRECT, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR PUNITIVE DAMAGES ARISING FROM OR RELATED TO YOUR USE OF — OR INABILITY TO USE — THE SITE, EVEN IF WE HAVE BEEN ADVISED OF THE POSSIBILITY OF SUCH DAMAGES.</p>
        <p>Our total liability to you for any claim arising out of or relating to these Terms or your use of the Site shall not exceed one hundred dollars ($100.00).</p>
        <p>Some jurisdictions do not allow the exclusion of implied warranties or limitation of liability for incidental or consequential damages, so some of the above limitations may not apply to you.</p>

        <h2 id="indemnification">10. Indemnification</h2>
        <p>You agree to defend, indemnify, and hold harmless Jerry &amp; Co. Home Improvement LLC and its owner, employees, and agents from and against any claims, liabilities, damages, losses, and expenses (including reasonable attorneys' fees) arising from or related to: (a) your use of the Site; (b) your violation of these Terms; or (c) your violation of any third-party rights.</p>

        <h2 id="governing-law">11. Governing law and jurisdiction</h2>
        <p>These Terms are governed by and construed in accordance with the laws of the <strong>Commonwealth of Massachusetts</strong>, without regard to its conflict-of-law provisions.</p>
        <p>Any dispute arising out of or relating to these Terms or your use of the Site shall be subject to the exclusive jurisdiction of the state and federal courts located in Middlesex County, Massachusetts. You consent to personal jurisdiction in those courts.</p>
        <p>Notwithstanding the above, nothing in these Terms prevents either party from seeking injunctive or other equitable relief in any court of competent jurisdiction.</p>

        <h2 id="changes">12. Changes to terms</h2>
        <p>We reserve the right to modify these Terms at any time. When we do, we will update the effective date at the top of this page. Material changes will be posted at least 14 days before taking effect. Your continued use of the Site after any change constitutes your acceptance of the updated Terms.</p>
        <p>We encourage you to review these Terms periodically.</p>

        <h2 id="contact">13. Contact us</h2>
        <p>Questions about these Terms? Contact us:</p>
        <address>
          <strong>Jerry &amp; Co. Home Improvement LLC</strong><br />
          MA HIC #208336 &nbsp;·&nbsp; Greater Boston, MA<br />
          <a href="mailto:jerry@jerryandcohome.com">jerry@jerryandcohome.com</a><br />
          <a href="tel:+13476026801">(347) 602-6801</a>
        </address>

      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  .legal-hero {
    background: var(--ink);
    color: var(--bone);
    padding: clamp(24px, 3.5vw, 48px) 0 clamp(32px, 4vw, 56px);
    border-bottom: 1px solid var(--line-dark);
  }
  .legal-hero :global(.breadcrumb-list) { color: rgba(247,243,234,0.4); margin-bottom: 20px; }
  .legal-hero :global(.breadcrumb-item a) { color: var(--gold); }
  .legal-hero :global([aria-current="page"]) { color: rgba(247,243,234,0.7); }
  .legal-hero :global(.sep) { color: rgba(247,243,234,0.28); opacity: 1; }
  .legal-hero .eyebrow { color: var(--gold); }
  .legal-hero h1 { color: var(--bone); font-size: clamp(2rem, 4vw, 3.25rem); margin-top: 8px; }
  .legal-meta {
    font-size: 14px;
    color: rgba(247,243,234,0.45);
    margin-top: 16px;
    letter-spacing: 0.01em;
  }

  .legal-body {
    background: var(--bone);
    padding: clamp(48px, 6vw, 80px) 0 clamp(64px, 8vw, 104px);
  }

  .legal-wrap {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  .legal-toc {
    position: sticky;
    top: 88px;
    padding: 24px 20px;
    background: var(--bone-deep);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
  }
  .toc-head {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0 0 14px;
  }
  .legal-toc ol {
    margin: 0;
    padding: 0 0 0 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .legal-toc li { margin: 0; }
  .legal-toc a {
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    line-height: 1.45;
    transition: color 0.15s;
  }
  .legal-toc a:hover { color: var(--forest); }

  .legal-prose { min-width: 0; }
  .legal-prose h2 {
    font-size: clamp(1.35rem, 2vw, 1.625rem);
    color: var(--forest);
    margin: 52px 0 16px;
    padding-top: 4px;
    border-top: 1px solid var(--line);
  }
  .legal-prose h2:first-child { margin-top: 0; border-top: none; }
  .legal-prose h3 {
    font-size: 1.0625rem;
    color: var(--ink);
    margin: 28px 0 10px;
    letter-spacing: -0.01em;
  }
  .legal-prose p {
    font-size: 1rem;
    line-height: 1.82;
    color: var(--text);
    margin-bottom: 18px;
  }
  .legal-prose ul, .legal-prose ol {
    margin: 0 0 18px 0;
    padding-left: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .legal-prose li {
    font-size: 1rem;
    line-height: 1.72;
    color: var(--text);
  }
  .legal-prose a { color: var(--gold-deep); text-decoration: underline; text-underline-offset: 2px; }
  .legal-prose a:hover { color: var(--forest); }
  .legal-prose address {
    font-style: normal;
    font-size: 1rem;
    line-height: 1.9;
    color: var(--text);
    background: var(--bone-deep);
    border: 1px solid var(--line);
    border-radius: var(--radius-xs);
    padding: 20px 24px;
    margin-top: 8px;
    display: inline-block;
  }

  @media (max-width: 860px) {
    .legal-wrap { grid-template-columns: 1fr; }
    .legal-toc { position: static; }
  }
</style>
